      "targets": [
        {
          "expr": "sum(rate(architect_agent_llm_requests_total[1m])) by (node)",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 20,
      "type": "row",
